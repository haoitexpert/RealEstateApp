<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RealEstateApp.Pages.HomePage"
             BackgroundColor="#F5F6FA">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══════════════════════════════════ -->
            <!--              HEADER                 -->
            <!-- ═══════════════════════════════════ -->
            <Grid Padding="24,50,24,24"
                  BackgroundColor="#1d94ab">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label x:Name="LblUsername"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="Find your best place to stay"
                           FontSize="14"
                           TextColor="#CCF0F7"/>
                </VerticalStackLayout>

                <!-- Avatar / Notification Icon -->
                <Frame Grid.Column="1"
                       WidthRequest="44"
                       HeightRequest="44"
                       CornerRadius="22"
                       BackgroundColor="#2aaec7"
                       Padding="0"
                       BorderColor="Transparent"
                       VerticalOptions="Center">
                    <Label Text="🔔"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>
            </Grid>

            <!-- ═══════════════════════════════════ -->
            <!--            SEARCH BAR               -->
            <!-- ═══════════════════════════════════ -->
            <Frame Margin="24,-22,24,0"
                   Padding="16,12"
                   CornerRadius="16"
                   BackgroundColor="White"
                   BorderColor="Transparent"
                   HasShadow="True">
                <HorizontalStackLayout Spacing="12">
                    <Image Source="search_icon.png"
                           Aspect="AspectFit"
                           HeightRequest="22"
                           WidthRequest="22"
                           VerticalOptions="Center"/>
                    <Label Text="Search properties, locations..."
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="#AAAAAA"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- ═══════════════════════════════════ -->
            <!--            CATEGORIES               -->
            <!-- ═══════════════════════════════════ -->
            <VerticalStackLayout Spacing="14" Margin="0,28,0,0">

                <Grid Padding="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Text="Categories"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1A1A2E"/>
                    <Label Grid.Column="1"
                           Text="See All"
                           FontSize="13"
                           TextColor="#1d94ab"
                           VerticalOptions="Center"/>
                </Grid>

                <CollectionView x:Name="CvCategories"
                                HeightRequest="90"
                                Margin="24,0,0,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="12" Orientation="Horizontal"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="16"
                                   Padding="14,10"
                                   BackgroundColor="White"
                                   BorderColor="Transparent"
                                   HasShadow="True"
                                   VerticalOptions="Center">
                                <VerticalStackLayout Spacing="6"
                                                     HorizontalOptions="Center">
                                    <Image Aspect="AspectFit"
                                           HeightRequest="32"
                                           WidthRequest="32"
                                           HorizontalOptions="Center"
                                           Source="{Binding FullImageUrl}"/>
                                    <Label Text="{Binding Name}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A2E"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <!-- ═══════════════════════════════════ -->
            <!--             TOP PICKS               -->
            <!-- ═══════════════════════════════════ -->
            <VerticalStackLayout Spacing="14" Margin="0,28,0,30">

                <Grid Padding="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Text="Top Picks"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1A1A2E"/>
                    <Label Grid.Column="1"
                           Text="See All"
                           FontSize="13"
                           TextColor="#1d94ab"
                           VerticalOptions="Center"/>
                </Grid>

                <CollectionView x:Name="CvTopPicks"
                                HeightRequest="340"
                                Margin="24,0,0,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="16" Orientation="Horizontal"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="20"
                                   Padding="0"
                                   BackgroundColor="White"
                                   BorderColor="Transparent"
                                   HasShadow="True"
                                   WidthRequest="230"
                                   IsClippedToBounds="True">
                                <Grid RowSpacing="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="170"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Property Image -->
                                    <Image Grid.Row="0"
                                           Source="{Binding FullImageUrl}"
                                           Aspect="AspectFill"/>

                                    <!-- Price Badge -->
                                    <Frame Grid.Row="0"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="0,12,12,0"
                                           Padding="10,5"
                                           CornerRadius="12"
                                           BackgroundColor="#1d94ab"
                                           BorderColor="Transparent">
                                        <Label Text="{Binding Price, StringFormat='${0:N0}'}"
                                               TextColor="White"
                                               FontSize="12"
                                               FontAttributes="Bold"/>
                                    </Frame>

                                    <!-- Info Section -->
                                    <VerticalStackLayout Grid.Row="1"
                                                         Spacing="5"
                                                         Padding="14,12,14,14">
                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1A1A2E"
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📍"
                                                   FontSize="11"
                                                   VerticalOptions="Center"/>
                                            <Label Text="{Binding Address}"
                                                   FontSize="12"
                                                   TextColor="#888888"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
