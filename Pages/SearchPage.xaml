<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RealEstateApp.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="SearchPage">
    <VerticalStackLayout>
        <Grid BackgroundColor="#1d94ab">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image
                x:Name="ImgBackBtn"
                Grid.Column="0"
                HeightRequest="30"
                HorizontalOptions="Center"
                Source="left_arrow_icon.png"
                WidthRequest="30" />
            <SearchBar
                x:Name="SbProperty"
                Grid.Column="1"
                Margin="5"
                BackgroundColor="White"
                Placeholder="Search"
                TextColor="Black" />
        </Grid>
        <CollectionView
            x:Name="CvSearch"
            Margin="0,10,0,0"
            SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Padding="10" FontSize="Medium" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>