<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage
    x:Class="RealEstateApp.Pages.CustomTabbedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:android="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:local="clr-namespace:RealEstateApp.Pages"
    android:TabbedPage.ToolbarPlacement="Bottom"
    SelectedTabColor="#1d94ab"
    UnselectedTabColor="#78909c">

    <NavigationPage
        Title="Home"
        BackgroundColor="#1d94ab"
        IconImageSource="home_icon.png">
        <x:Arguments>
            <local:HomePage />
        </x:Arguments>

    </NavigationPage>

    <local:BookmarksPage Title="Saved" IconImageSource="bookmark_icon.png" />
    <local:SettingPage Title="Settings" IconImageSource="settings_icon.png" />
</TabbedPage>